# Copie para .env.deploy e preencha com seus valores reais.
# .env.deploy está no .gitignore e nunca deve ser commitado.
#
# Uso:
#   source infrastructure/.env.deploy && ./infrastructure/deploy-frontend.sh

export AWS_REGION="us-east-1"
export S3_BUCKET="meridian-frontend-<account-id>"
export CLOUDFRONT_DISTRIBUTION_ID="<distribution-id>"
export VITE_API_URL="https://<service-id>.us-east-1.awsapprunner.com"
